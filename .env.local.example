# =====================================================================
# .env.local.example — template para desenvolvimento local
# =====================================================================
# Copie para .env.local e ajuste os valores ao seu ambiente.
# O arquivo .env.local NUNCA é commitado (coberto pelo .gitignore).
# =====================================================================

# --- Frontend (Next.js) -----------------------------------------------
# Variáveis prefixadas com NEXT_PUBLIC_ são expostas ao browser.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Backend / Server-only --------------------------------------------
# Estas variáveis NÃO devem ser expostas ao client. Sem prefixo NEXT_PUBLIC_,
# o Next.js automaticamente as mantém apenas no contexto de servidor.
DATABASE_URL=postgresql://copilot:copilot@localhost:5432/copilot
REDIS_URL=redis://localhost:6379
